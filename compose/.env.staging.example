# Variables pour la stack STAGING.
# Copier en `compose/.env.staging` sur la VM et remplir les vraies valeurs.

# ── Domaine ────────────────────────────────────────────────────────────────
DOMAIN=cesizen-staging.duckdns.org

# Domaine pour pgAdmin (commenter si vous désactivez le service pgadmin)
PGADMIN_DOMAIN=cesizen-pgadmin.duckdns.org

# ── Tags d'images à pull ───────────────────────────────────────────────────
API_TAG=develop
WEB_TAG=develop

# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=cesizen
POSTGRES_PASSWORD=CHANGE_ME_strong_password_min_16_chars
POSTGRES_DB=cesizen

# ── API : secrets JWT ──────────────────────────────────────────────────────
# Générer des valeurs aléatoires fortes (≥ 32 caractères) :  openssl rand -base64 48
ACCESS_TOKEN_SECRET=CHANGE_ME_access_token_secret_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=CHANGE_ME_refresh_token_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d

# ── pgAdmin (optionnel) ────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@cesizen.local
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password
