# Variables pour la stack PRODUCTION.
# Copier en `compose/.env.prod` sur la VM et remplir les vraies valeurs.
# Les secrets DOIVENT être différents de ceux du staging.

# ── Domaine ────────────────────────────────────────────────────────────────
DOMAIN=cesizen-prod.duckdns.org

# ── Tags d'images à pull ───────────────────────────────────────────────────
# :latest est poussé par GitHub Actions lors d'un tag git v* (release).
API_TAG=latest
WEB_TAG=latest

# ── Postgres (DB ISOLÉE du staging — autre user/password recommandé) ───────
POSTGRES_USER=cesizen
POSTGRES_PASSWORD=CHANGE_ME_DIFFERENT_FROM_STAGING
POSTGRES_DB=cesizen

# ── API : secrets JWT (DIFFÉRENTS du staging) ──────────────────────────────
# openssl rand -base64 48
ACCESS_TOKEN_SECRET=CHANGE_ME_prod_access_secret_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=CHANGE_ME_prod_refresh_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d
