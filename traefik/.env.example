# Variables pour la stack infrastructure (Traefik + Watchtower).
# Copier en `traefik/.env` sur la VM et remplir les vraies valeurs.

# Email d'enregistrement Let's Encrypt (notifications d'expiration).
# Pas critique en pratique : Traefik renouvelle automatiquement les certs 30j avant.
LETSENCRYPT_EMAIL=nicolas.descarp@outlook.fr

# URL shoutrrr du webhook Discord pour les notifications Watchtower.
# Format : discord://TOKEN@CHANNEL_ID
# Comment l'obtenir : à partir de l'URL webhook Discord
#   https://discord.com/api/webhooks/<CHANNEL_ID>/<TOKEN>
# → on inverse l'ordre et on préfixe avec discord:// :
#   discord://<TOKEN>@<CHANNEL_ID>
DISCORD_SHOUTRRR_URL=discord://CHANGE_ME_TOKEN@CHANGE_ME_CHANNEL_ID
